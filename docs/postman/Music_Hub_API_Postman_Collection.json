  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "00 Signup Evidence - SamuelSmith@test.com",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"SamuelSmith@test.com\",\n  \"password\": \"Sam@12345\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "signup"
              ]
            },
            "description": "Optional signup evidence request. If seed.js has already created this user, a 400 duplicate-user response is acceptable evidence because seed.js creates the required users with bcrypt-hashed passwords."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signup evidence returns created or duplicate-user response', function () { pm.expect([201, 400]).to.include(pm.response.code); });",
                  "pm.test('Signup evidence message is expected', function () { const message = pm.response.json().message; pm.expect(['User created', 'Email already in use']).to.include(message); });"
                ]
              }
            }
          ]
        },
