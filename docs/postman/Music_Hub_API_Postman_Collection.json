              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"SamuelSmith@test.com\",\n  \"password\": \"Sam@12345\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "login"
              ]
            },
            "description": "Expected response: 200 OK with token and expiresIn."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('JWT token is returned', function () { pm.expect(json.token).to.be.a('string').and.not.empty; });",
                  "pm.test('expiresIn is 3600', function () { pm.expect(json.expiresIn).to.eql(3600); });",
                  "pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ]
        },
