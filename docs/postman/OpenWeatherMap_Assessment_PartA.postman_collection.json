      "name": "Weather by City",
      "item": [
        {
          "name": "Auckland Weather",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://api.openweathermap.org/data/2.5/weather?q=Auckland&units=metric&appid=30dbb321671ff8c9858ee6a3d2190359",
              "protocol": "https",
              "host": [
                "api",
                "openweathermap",
                "org"
              ],
              "path": [
                "data",
                "2.5",
                "weather"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "Auckland"
                },
                {
                  "key": "units",
                  "value": "metric"
                },
                {
                  "key": "appid",
                  "value": "30dbb321671ff8c9858ee6a3d2190359"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "",
                  "pm.test('weather array exists', function () {",
                  "  pm.expect(jsonData).to.have.property('weather');",
                  "  pm.expect(jsonData.weather).to.be.an(\"array\");",
                  "});",
                  "",
                  "pm.test('main.temp_min exists', function () {",
                  "  pm.expect(jsonData).to.have.property('main');",
                  "  pm.expect(jsonData.main).to.have.property('temp_min');",
                  "});",
                  "",
                  "pm.test('main.temp_max exists', function () {",
                  "  pm.expect(jsonData).to.have.property('main');",
                  "  pm.expect(jsonData.main).to.have.property('temp_max');",
                  "});",
                  "",
                  "pm.test('weather[0].description exists', function () {",
                  "  pm.expect(jsonData.weather[0]).to.exist;",
                  "  pm.expect(jsonData.weather[0]).to.have.property('description');",
                  "});"
                ]
              }
            }
          ]
        },
